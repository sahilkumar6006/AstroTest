// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  user
  astrologer
  admin
}

enum Gender {
  male
  female
  other
}

enum ZodiacSign {
  aries
  taurus
  gemini
  cancer
  leo
  virgo
  libra
  scorpio
  sagittarius
  capricorn
  aquarius
  pisces
}

enum Language {
  en
  hi
  ta
  te
  bn
}

enum SessionType {
  chat
  call
  video
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum TransactionType {
  credit
  debit
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone             String    @unique @db.VarChar(20)
  role              Role      @default(user)
  name              String?   @db.VarChar(100)
  email             String?   @unique @db.VarChar(255)
  avatarUrl         String?
  dateOfBirth       DateTime? @db.Date
  gender            Gender?
  zodiacSign        ZodiacSign?
  language          Language  @default(hi)
  walletBalance     Int       @default(0) // paise
  isBanned          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  refreshTokens     RefreshToken[]
  astrologerProfile AstrologerProfile?
  userSessions      Session[]          @relation("UserSessions")
  astrologerSessions Session[]         @relation("AstrologerSessions")
  walletTransactions WalletTransaction[]
  paymentOrders     PaymentOrder[]
  reviews           Review[]

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique @db.VarChar(255)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model AstrologerProfile {
  id               String    @id @db.Uuid
  bio              String?
  skills           String[]
  languages        String[]
  experience       Int       @default(0) // years
  chatPricePerMin  Int       @default(1500) // paise
  callPricePerMin  Int       @default(2000)
  videoPricePerMin Int       @default(2500)
  rating           Decimal   @default(0) @db.Decimal(3, 2)
  totalReviews     Int       @default(0)
  totalSessions    Int       @default(0)
  totalEarnings    Int       @default(0) // paise (gross)
  isVerified       Boolean   @default(false)
  isOnline         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [id], references: [id])

  @@map("astrologer_profiles")
}

model Session {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @db.Uuid
  astrologerId    String        @db.Uuid
  type            SessionType
  status          SessionStatus @default(PENDING)
  pricePerMin     Int           // paise, snapshot at session start
  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  totalCost       Int?          // paise
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  user            User          @relation("UserSessions", fields: [userId], references: [id])
  astrologer      User          @relation("AstrologerSessions", fields: [astrologerId], references: [id])
  review          Review?

  @@map("sessions")
}

model WalletTransaction {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @db.Uuid
  type          TransactionType
  amount        Int             // paise, always positive
  balanceAfter  Int
  description   String?
  referenceId   String?         @db.Uuid // sessionId or paymentOrderId
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])

  @@map("wallet_transactions")
}

model PaymentOrder {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String        @db.Uuid
  razorpayOrderId     String        @unique @db.VarChar(100)
  razorpayPaymentId   String?       @unique @db.VarChar(100)
  amount              Int           // paise
  currency            String        @default("INR") @db.VarChar(3)
  status              PaymentStatus @default(PENDING)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id])

  @@map("payment_orders")
}

model Review {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId     String    @unique @db.Uuid
  userId        String    @db.Uuid
  astrologerId  String    @db.Uuid
  rating        Int       // 1-5
  comment       String?   @db.VarChar(500)
  createdAt     DateTime  @default(now())

  session       Session   @relation(fields: [sessionId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@map("reviews")
}
