{
  "info": {
    "_postman_id": "a1b2c3d4-astro-dev",
    "name": "AstroTalk API — Development",
    "description": "Local dev (NODE_ENV=development): magic OTP from OTP_MAGIC_CODE (default 123456). E.164 phone required. Refresh cookie is set on verify-otp; enable Postman cookie jar for /auth/refresh.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "phone", "value": "+919999999999" },
    { "key": "accessToken", "value": "" },
    { "key": "magicOtp", "value": "123456" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/send-otp",
            "description": "Check server logs for [DEV OTP] line, or use magicOtp (default 123456) if OTP_MAGIC_CODE matches."
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data && j.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', j.data.accessToken);",
                  "  console.log('Saved accessToken to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"{{magicOtp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-otp",
            "description": "Sets httpOnly refreshToken cookie (path /api/v1/auth). Postman captures it if cookies are enabled."
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "description": "Requires refreshToken cookie from Verify OTP. Enable Cookies in Postman settings."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "description": "Clears refresh cookie; works if cookie still present."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Run Verify OTP first so accessToken is set."
          }
        },
        {
          "name": "Patch me (display name)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Dev User\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "displayName required key; use string or null to clear."
          }
        }
      ]
    }
  ]
}
